<!DOCTYPE html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>جميع التقييمات</title>
    <link rel="stylesheet" href="/AllEvaluation.css" />
  </head>
  <body>
    <!--start header-->
    <div class="header">
      <div class="header-container">
        <div class="logo"><img src="/image/logo.jpg" alt="خيم المندي " /></div>
        <div class="name">
          <h1>ليالي العرب</h1>
        </div>
      </div>
    </div>
    <!--end header-->

    <div class="container">
      <h1>📊 تقييمات العملاء</h1>

      <!-- فلتر البحث بالتاريخ
      <div class="filter-section">
        <h3>🔍 فلتر التقييمات حسب التاريخ</h3>
        <div class="filter-inputs">
          <div class="filter-group">
            <label for="startDate">من تاريخ:</label>
            <input type="date" id="startDate" class="date-input" />
          </div>
          <div class="filter-group">
            <label for="endDate">إلى تاريخ:</label>
            <input type="date" id="endDate" class="date-input" />
          </div>
          <button id="filterBtn" class="filter-btn">بحث 🔎</button>
          <button id="resetBtn" class="reset-btn">إعادة تعيين 🔄</button>
        </div>
      </div> -->

      <div class="delete-section">
        <form action="/api/deleteall?_method=DELETE" method="POST">
          <button type="submit" class="delete-all-btn">
            🗑️ حذف جميع التقييمات
          </button>
        </form>
      </div>

      <!-- ✅ Stats + تحليلات -->
      <% if (ratings.length > 0) {
        const avgs = ratings.map(r => ({
          avg: (r.cashier + r.cleanliness + r.foodQuality + r.service) / 4,
          name: r.name
        }));
        const totalAvg = (avgs.reduce((s, r) => s + r.avg, 0) / ratings.length).toFixed(1);
        const best  = avgs.reduce((a, b) => a.avg > b.avg ? a : b);
        const worst = avgs.reduce((a, b) => a.avg < b.avg ? a : b);

        const avgCashier  = (ratings.reduce((s,r)=>s+r.cashier,0)       / ratings.length).toFixed(1);
        const avgClean    = (ratings.reduce((s,r)=>s+r.cleanliness,0)   / ratings.length).toFixed(1);
        const avgFood     = (ratings.reduce((s,r)=>s+r.foodQuality,0)   / ratings.length).toFixed(1);
        const avgService  = (ratings.reduce((s,r)=>s+r.service,0)       / ratings.length).toFixed(1);

        const excellent = avgs.filter(r => r.avg >= 8).length;
        const good      = avgs.filter(r => r.avg >= 6 && r.avg < 8).length;
        const poor      = avgs.filter(r => r.avg < 6).length;
      %>

      <!-- بطاقات الإحصاء -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">📈 إجمالي التقييمات</div>
          <p class="stat-number"><%= ratings.length %></p>
        </div>
        <div class="stat-card">
          <div class="stat-label">⭐ متوسط عام</div>
          <p class="stat-number"><%= totalAvg %>/10</p>
        </div>
        <div class="stat-card">
          <div class="stat-label">🏆 أعلى تقييم</div>
          <p class="stat-number" style="color:#1D9E75"><%= best.avg.toFixed(1) %>/10</p>
          <div class="stat-sub"><%= best.name %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">📉 أدنى تقييم</div>
          <p class="stat-number" style="color:#A32D2D"><%= worst.avg.toFixed(1) %>/10</p>
          <div class="stat-sub"><%= worst.name %></div>
        </div>
      </div>

      <!-- متوسط كل تصنيف -->
      <div class="cat-bars">
        <div class="cat-title">📊 متوسط كل تصنيف</div>
        <div class="bar-row">
          <span class="bar-label">الكاشير</span>
          <div class="bar-track"><div class="bar-fill" style="width:<%= avgCashier * 10 %>%;background:#1D9E75"></div></div>
          <span class="bar-val"><%= avgCashier %>/10</span>
        </div>
        <div class="bar-row">
          <span class="bar-label">النظافة</span>
          <div class="bar-track"><div class="bar-fill" style="width:<%= avgClean * 10 %>%;background:#3B8BD4"></div></div>
          <span class="bar-val"><%= avgClean %>/10</span>
        </div>
        <div class="bar-row">
          <span class="bar-label">جودة الطعام</span>
          <div class="bar-track"><div class="bar-fill" style="width:<%= avgFood * 10 %>%;background:#BA7517"></div></div>
          <span class="bar-val"><%= avgFood %>/10</span>
        </div>
        <div class="bar-row">
          <span class="bar-label">الخدمة</span>
          <div class="bar-track"><div class="bar-fill" style="width:<%= avgService * 10 %>%;background:#534AB7"></div></div>
          <span class="bar-val"><%= avgService %>/10</span>
        </div>
      </div>

      <!-- توزيع التقييمات -->
      <div class="dist-row">
        <div class="dist-card">
          <div class="dist-count" style="color:#1D9E75"><%= excellent %></div>
          <div class="dist-lbl">⭐ ممتاز (≥8)</div>
        </div>
        <div class="dist-card">
          <div class="dist-count" style="color:#BA7517"><%= good %></div>
          <div class="dist-lbl">👍 جيد (6–8)</div>
        </div>
        <div class="dist-card">
          <div class="dist-count" style="color:#A32D2D"><%= poor %></div>
          <div class="dist-lbl">⚠️ ضعيف (&lt;6)</div>
        </div>
      </div>

      <% } else { %>
      <!-- لو مفيش تقييمات -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">📈 إجمالي التقييمات</div>
          <p class="stat-number">0</p>
        </div>
        <div class="stat-card">
          <div class="stat-label">⭐ متوسط عام</div>
          <p class="stat-number">-</p>
        </div>
        <div class="stat-card">
          <div class="stat-label">🏆 أعلى تقييم</div>
          <p class="stat-number">-</p>
        </div>
        <div class="stat-card">
          <div class="stat-label">📉 أدنى تقييم</div>
          <p class="stat-number">-</p>
        </div>
      </div>
      <% } %>

      <!-- جدول التقييمات -->
      <div class="table-wrapper">
        <table class="ratings-table">
          <thead>
            <tr>
              <th>#</th>
              <th>الاسم</th>
              <th>رقم الهاتف</th>
              <th>رقم الطاولة</th>
              <th>الكاشير</th>
              <th>النظافة</th>
              <th>جودة الطعام</th>
              <th>الخدمة</th>
              <th>المتوسط</th>
              <th>ملاحظات</th>
              <th>التاريخ</th>
            </tr>
          </thead>
          <tbody id="ratingsTableBody">
            <% if (ratings.length === 0) { %>
            <tr>
              <td colspan="11" class="no-data">لا توجد تقييمات حتى الآن</td>
            </tr>
            <% } else { %>
              <% ratings.forEach(function(rating, index) {
                const avg = ((rating.cashier + rating.cleanliness + rating.foodQuality + rating.service) / 4).toFixed(1);
                const ratingClass = avg >= 8 ? 'excellent' : avg >= 6 ? 'good' : 'poor';
              %>
              <tr class="<%= ratingClass %>" data-date="<%= rating.createdAt %>">
                <td><%= index + 1 %></td>
                <td class="name-cell"><strong><%= rating.name %></strong></td>
                <td class="phone-cell"><%= rating.phone || '-' %></td>
                <td><span class="badge"><%= rating.numGTables %></span></td>
                <td><span class="rating-value"><%= rating.cashier %>/10</span></td>
                <td><span class="rating-value"><%= rating.cleanliness %>/10</span></td>
                <td><span class="rating-value"><%= rating.foodQuality %>/10</span></td>
                <td><span class="rating-value"><%= rating.service %>/10</span></td>
                <td><span class="average <%= ratingClass %>"><%= avg %></span></td>
                <td class="notes-cell"><%= rating.notes || '-' %></td>
                <td class="date-cell"><%= new Date(rating.createdAt).toLocaleDateString('ar-EG') %></td>
              </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <script src="/AllEvaluation.js"></script>
  </body>
</html>
