<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تقييم العملاء</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body>
      <!--start header-->
    <div class="header">
      <div class="header-container">
        <div class="logo"><img src="/image/logo.jpg" alt="خيم المندي " /></div>
        <div class="name">
          <h1>ليالي العرب
  </h1>
        </div>
      </div>
    </div>
    <!--end header-->

    <div class="container">
        <h1>قيم تجربتك معنا</h1>

<form id="ratingForm" action="/api/submitrating" method="POST">
          <div class="inputs">
              <div class="input-wrapper">
                  <input type="text" class="input" id="nameInput" placeholder="اكتب اسمك" name="name"/>
                  <span class="icon">👤</span>
              </div>
              <div class="input-wrapper">
                  <input type="tel" class="input" id="phoneInput" placeholder="رقم الهاتف" name="phone"/>
                  <span class="icon">📱</span>
              </div>
              <div class="input-wrapper">
                  <input type="number" class="input" id="numGTablesInput" placeholder="رقم الطاولة" name="numGTables"/>
                  <span class="icon">🪑</span>
              </div>
          </div>

          <!-- التقييمات -->
          <label for="cashier">تقييم الكاشير (1-10):</label>
          <input type="range" id="cashier" name="cashier" min="1" max="10" value="5">
          <span id="cashierValue">5</span><br><br>

          <label for="cleanliness">تقييم نظافة المكان (1-10):</label>
          <input type="range" id="cleanliness" name="cleanliness" min="1" max="10" value="5">
          <span id="cleanlinessValue">5</span><br><br>

          <label for="foodQuality">تقييم جودة الطعام (1-10):</label>
          <input type="range" id="foodQuality" name="foodQuality" min="1" max="10" value="5">
          <span id="foodQualityValue">5</span><br><br>

          <label for="service">تقييم الخدمة (1-10):</label>
          <input type="range" id="service" name="service" min="1" max="10" value="5">
          <span id="serviceValue">5</span><br><br>

          <!-- ✅ حقل الملاحظات -->
          <div class="notes-section">
              <label for="notes">ملاحظات أخرى (اختياري):</label>
              <textarea
                  id="notes"
                  name="notes"
                  class="notes-textarea"
                  placeholder="شاركنا رأيك أو أي ملاحظات إضافية..."
                  rows="4"
              ></textarea>
          </div>

          <button type="submit">إرسال التقييم</button>
        </form>
        <p id="message"></p>
    </div>
    <script src="/index.js"></script>
</body>
</html>
